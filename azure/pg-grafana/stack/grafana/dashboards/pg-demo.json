{
  "uid": "azure-pg-demo",
  "title": "Azure PostgreSQL Demo",
  "tags": ["azure", "postgresql", "demo"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Database storage used",
      "description": "Logical size of each database, from the Postgres exporter (pg_database_size_bytes).",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "expr": "pg_database_size_bytes{datname!~\"template.*\"}",
          "legendFormat": "{{datname}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Queries per second (1m rate)",
      "description": "Transactions per second against the postgres management database, averaged over a 1-minute window. Driven by the db-load container.",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "qps",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 40,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "expr": "sum(rate(pg_stat_database_xact_commit{datname=\"postgres\"}[1m])) + sum(rate(pg_stat_database_xact_rollback{datname=\"postgres\"}[1m]))",
          "legendFormat": "queries/sec"
        }
      ]
    }
  ]
}
